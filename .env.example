# ═══════════════════════════════════════════════════
#  PasekSaaS Frontend — Environment Configuration
#  Copy this to .env and fill in real values
# ═══════════════════════════════════════════════════

# ── Database ──────────────────────────────────────
DB_HOST=localhost
DB_USER=
DB_PASS=
DB_NAME=

# ── Site Configuration ────────────────────────────
SITE_DOMAIN=websitewayan.my.id
MASTER_WA=6281234567890

# ── Security ──────────────────────────────────────
# Generate with: php -r "echo bin2hex(random_bytes(32));"
COOKIE_SECRET=
# Set to 0 in production
DISPLAY_ERRORS=0
